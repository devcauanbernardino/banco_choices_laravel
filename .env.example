APP_NAME="Banco de Choices"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# --- Produção (servidor) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://seu-dominio.tld
# LOG_LEVEL=error
#
# Cookies HTTPS (defina quando todo o site servir em HTTPS):
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
#
# Opcional: camada extra nas sessões:
# SESSION_ENCRYPT=true
#
# Atrás de load balancer / proxy reverso (Forwarded-*):
# TRUSTED_PROXIES=*
#
# Cabeçalho HSTS mesmo sem detetar HTTPS na app (LB termina TLS):
# SECURITY_FORCE_HSTS=false

# --- Mercado Pago (testes em localhost) ---
# Subir o site com: php artisan serve  → use a mesma origem em APP_URL (ex.: http://127.0.0.1:8000)
# Credenciais de TESTE: https://www.mercadopago.com.br/developers/panel/credentials
# Em produção use credenciais LIVE (sem prefixo TEST-) e MP_WEBHOOK_SECRET obrigatório.
# MP_ACCESS_TOKEN=TEST-xxxxxxxx
# MP_PUBLIC_KEY=TEST-xxxxxxxx
# MP_CURRENCY_ID=ARS
# MP_WEBHOOK_SECRET=
#
# Produção: validação de assinatura no webhook (predefinido por APP_ENV=production).
# MP_REQUIRE_WEBHOOK_SIGNATURE=
#
# SITE_URL costuma ser igual ao APP_URL (deixe em branco para herdar APP_URL em config/mercadopago.php)
#
# Opcional: túnel HTTPS (ngrok, Cloudflare Tunnel) para auto_return, botão "Voltar ao site" e webhook:
# MP_CHECKOUT_BASE_URL=https://xxxx.ngrok-free.app
#
# E-mail de credenciais com MAIL_MAILER=log → ver storage/logs/laravel.log

# Optional: path under public/ (e.g. img/logo.png). Overrides automatic logo detection.
# BRAND_LOGO=

# Locale por defeito alinhado ao produto (sessão pode usar es_AR / pt_BR / en_US).
APP_LOCALE=es_AR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Desenvolvimento local: SQLite. Produção: MySQL/MariaDB/PostgreSQL + backups e restore testados.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=banco_choices
# DB_USERNAME=
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Emails que não recebem matérias padrão ao entrar (lista CSV). Produção: deixe vazio ou omita.
# microbiologia.solo@bancodechoices.local já está na lista fixa em config/test_users.php.
# TEST_USER_SKIP_DEFAULT_MATERIAS=outro@example.com
