# Copiar para o servidor: cp .env.production.example .env
# Depois: php artisan key:generate  (só se APP_KEY estiver vazio)
#         php artisan migrate --force
#         php artisan config:cache route:cache view:cache

APP_NAME="Banco de Choices"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://bancodechoices.com

SITE_URL=https://bancodechoices.com

LOG_CHANNEL=stack
LOG_LEVEL=error

APP_LOCALE=es_AR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=

TRUSTED_PROXIES=*

# MySQL/MariaDB (ajuste credenciais)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bancodechoices
DB_USERNAME=
DB_PASSWORD=

QUEUE_CONNECTION=sync
CACHE_STORE=file

# Mercado Pago LIVE (sem prefixo TEST-)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_CURRENCY_ID=ARS
MP_WEBHOOK_SECRET=

# E-mail transacional (caixa criada: contato@bancodechoices.com)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=contato@bancodechoices.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="contato@bancodechoices.com"
MAIL_FROM_NAME="${APP_NAME}"

# Opcional: redes na landing
# LANDING_WHATSAPP_URL=
# LANDING_INSTAGRAM_URL=
